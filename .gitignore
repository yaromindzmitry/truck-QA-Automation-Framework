# ══════════════════════════════════════════════════════════════════════════════
#  truck1.eu QA — .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyd
*.pyo
.Python
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/
.env
.env.*
!.env.example

# ── Pytest & Coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.hypothesis/

# ── Test reports — DO NOT COMMIT, only in CI artifacts ────────────────────────
reports/*.html
reports/*.json
reports/*.csv
reports/*.xml
reports/screenshots/
# Exception: demo artifacts can be kept
!reports/.gitkeep

# ── Playwright ─────────────────────────────────────────────────────────────────
# Never commit — may contain sessions, cookies, personal data
playwright/.auth/
playwright/storage_state*.json
storage_state*.json
auth_state*.json
test-results/
playwright-report/
playwright/traces/
*.trace
*.webm
*.zip

# ── Allure ──────────────────────────────────────────────────────────────────────
allure-results/
allure-report/

# ── k6 output ───────────────────────────────────────────────────────────────────
reports/k6_*.json

# ── Secrets — CRITICAL: never commit ──────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
secrets.yml
secrets.yaml
*_secrets.py
credentials.json
service_account.json
token.json

# ── Editors / OS ────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace

# ── Logs ────────────────────────────────────────────────────────────────────────
*.log
logs/
locust_log*.txt

# ── Temp ────────────────────────────────────────────────────────────────────────
*.tmp
*.bak
*.orig
~$*
