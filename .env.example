# ══════════════════════════════════════════════════════════════════════════════
#  truck1.eu QA — Environment Variables
#  Copy this file to .env and fill in your values:
#  cp .env.example .env
#
#  ❗ NEVER commit .env — it's added to .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── Main Settings ──────────────────────────────────────────────────────────────
# URL of the site under test
BASE_URL=https://www.truck1.eu

# Default locale (en, de, pl, lt, lv, ee, ru, cs, sk, ro, bg)
DEFAULT_LOCALE=en

# ── Playwright ────────────────────────────────────────────────────────────────
# Browser mode: true = show browser, false = headless
HEADED=false

# Slow down actions in ms (0 = no slowdown)
SLOW_MO=0

# Timeout in ms (default 30000)
# PLAYWRIGHT_TIMEOUT=30000

# ── Optional (for advanced scenarios) ──────────────────────────────────────────
# Staging environment URL (if available)
# STAGING_URL=https://staging.truck1.eu

# Slack webhook for failure notifications (optional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/HERE

# ── For CI (GitHub Actions) — set as GitHub Secrets ───────────────────────────
# Do not add real values here!
# In CI use: Settings → Secrets and variables → Actions
